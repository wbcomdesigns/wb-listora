#!/usr/bin/env bash
# Pre-push hook — runs the local-CI gate before allowing the push.
#
# Activate in this clone with:
#   composer install-hooks
# (which runs `git config core.hooksPath bin/git-hooks` — one-time setup).
#
# Bypass for genuine emergencies:
#   SKIP_LOCAL_CI=1 git push
#   git push --no-verify
#
# Generated by wp-plugin-onboard skill. Edit freely.

set -uo pipefail

if [ "${SKIP_LOCAL_CI:-0}" = "1" ]; then
  echo "SKIP_LOCAL_CI=1 — skipping local-CI gate."
  exit 0
fi

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$ROOT_DIR"

echo "Pre-push: running composer ci:no-journeys (browser gate runs separately)..."
composer ci:no-journeys || {
  echo ""
  echo "Local-CI failed. Fix the errors above before pushing."
  echo "Bypass (emergencies only): SKIP_LOCAL_CI=1 git push"
  exit 1
}
