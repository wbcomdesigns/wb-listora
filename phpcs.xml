<?xml version="1.0"?>
<ruleset name="WB Listora">
	<description>WordPress Coding Standards for WB Listora plugin.</description>

	<!-- Scan these paths -->
	<file>wb-listora.php</file>
	<file>includes</file>
	<file>blocks</file>
	<file>uninstall.php</file>

	<!-- Exclude paths -->
	<exclude-pattern>vendor/*</exclude-pattern>
	<exclude-pattern>node_modules/*</exclude-pattern>
	<exclude-pattern>build/*</exclude-pattern>
	<exclude-pattern>tests/*</exclude-pattern>
	<exclude-pattern>assets/vendor/*</exclude-pattern>

	<!-- Use WordPress standards -->
	<rule ref="WordPress">
		<!-- Allow short array syntax -->
		<exclude name="Generic.Arrays.DisallowShortArraySyntax"/>
		<!-- Allow short ternary (Universal sniff in WPCS 3.x) -->
		<exclude name="Universal.Operators.DisallowShortTernary"/>
		<!-- PSR-4 autoloading -->
		<exclude name="WordPress.Files.FileName"/>
		<!-- Yoda conditions not required -->
		<exclude name="WordPress.PHP.YodaConditions"/>
		<!-- Global variable override (used in block templates) -->
		<exclude name="WordPress.WP.GlobalVariablesOverride"/>
		<!-- Non-prefixed variables in block templates -->
		<exclude name="WordPress.NamingConventions.PrefixAllGlobals.NonPrefixedVariableFound"/>
		<!-- Custom tables use direct DB queries — handled inline -->
		<exclude name="WordPress.DB.DirectDatabaseQuery"/>
		<exclude name="WordPress.DB.PreparedSQL.InterpolatedNotPrepared"/>
		<!-- Comment style exclusions -->
		<exclude name="Squiz.Commenting.FileComment"/>
		<exclude name="Squiz.Commenting.FunctionComment"/>
		<exclude name="Squiz.Commenting.ClassComment"/>
		<exclude name="Squiz.Commenting.InlineComment"/>
		<exclude name="Squiz.Commenting.VariableComment"/>
		<exclude name="Squiz.Commenting.BlockComment"/>
		<exclude name="Squiz.Commenting.FunctionCommentThrowTag"/>
		<exclude name="Generic.Commenting.DocComment"/>
		<!-- Loop size function warnings (count in foreach) -->
		<exclude name="Squiz.PHP.DisallowSizeFunctionsInLoops"/>
		<!-- Increment/decrement usage style -->
		<exclude name="Squiz.Operators.IncrementDecrementUsage"/>
		<!-- Missing translators comment (low priority) -->
		<exclude name="WordPress.WP.I18n.MissingTranslatorsComment"/>
	</rule>

	<!-- Plugin-specific settings -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="wb-listora"/>
			</property>
		</properties>
	</rule>

	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="wb_listora"/>
				<element value="listora"/>
				<element value="WBListora"/>
				<element value="WB_LISTORA"/>
			</property>
		</properties>
	</rule>

	<rule ref="WordPress.WP.Capabilities">
		<properties>
			<property name="custom_capabilities" type="array">
				<element value="edit_listora_listing"/>
				<element value="edit_listora_listings"/>
				<element value="edit_others_listora_listings"/>
				<element value="edit_published_listora_listings"/>
				<element value="publish_listora_listings"/>
				<element value="delete_listora_listing"/>
				<element value="delete_listora_listings"/>
				<element value="delete_others_listora_listings"/>
				<element value="delete_published_listora_listings"/>
				<element value="read_private_listora_listings"/>
				<element value="manage_listora_settings"/>
				<element value="moderate_listora_reviews"/>
				<element value="manage_listora_claims"/>
				<element value="manage_listora_types"/>
				<element value="submit_listora_listing"/>
			</property>
		</properties>
	</rule>

	<!-- PHP compatibility -->
	<config name="testVersion" value="7.4-"/>

	<!-- Show progress and colors -->
	<arg value="ps"/>
	<arg name="colors"/>
	<arg name="extensions" value="php"/>
</ruleset>
