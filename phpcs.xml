<?xml version="1.0"?>
<ruleset name="WB Listora">
    <description>WordPress Coding Standards for WB Listora</description>

    <file>.</file>
    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>node_modules/*</exclude-pattern>
    <exclude-pattern>build/*</exclude-pattern>
    <exclude-pattern>assets/js/vendor/*</exclude-pattern>
    <exclude-pattern>seed-demo.php</exclude-pattern>

    <arg name="extensions" value="php"/>
    <arg value="sp"/>

    <rule ref="WordPress-Extra">
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
    </rule>

    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="wb-listora"/>
            </property>
        </properties>
    </rule>

    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="wb_listora"/>
                <element value="listora"/>
                <element value="WBListora"/>
            </property>
        </properties>
    </rule>

    <rule ref="WordPress.WP.Capabilities">
        <properties>
            <property name="custom_capabilities" type="array">
                <element value="edit_listora_listings"/>
                <element value="edit_others_listora_listings"/>
                <element value="publish_listora_listings"/>
                <element value="delete_listora_listings"/>
                <element value="manage_listora_types"/>
                <element value="manage_listora_settings"/>
                <element value="moderate_listora_reviews"/>
                <element value="moderate_listora_claims"/>
            </property>
        </properties>
    </rule>

    <config name="minimum_wp_version" value="6.4"/>
    <config name="testVersion" value="7.4-"/>
</ruleset>
