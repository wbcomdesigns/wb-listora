{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "listora/listing-submission",
	"version": "1.0.0",
	"title": "Listing Submission",
	"category": "listora",
	"icon": "plus-alt",
	"description": "Multi-step frontend listing submission form with type-driven fields, media upload, and preview.",
	"keywords": [ "submit", "add", "listing", "form" ],
	"supports": {
		"html": false,
		"align": [ "wide" ],
		"spacing": { "margin": true, "padding": true }
	},
	"attributes": {
		"listingType": { "type": "string", "default": "" },
		"showTypeStep": { "type": "boolean", "default": true },
		"requireLogin": { "type": "boolean", "default": true },
		"showTerms": { "type": "boolean", "default": true },
		"termsPageId": { "type": "number", "default": 0 },
		"redirectAfterSubmit": { "type": "string", "default": "dashboard" },
		"uniqueId": { "type": "string", "default": "" },
		"padding": { "type": "object" },
		"paddingTablet": { "type": "object" },
		"paddingMobile": { "type": "object" },
		"paddingUnit": { "type": "string", "default": "px" },
		"margin": { "type": "object" },
		"marginTablet": { "type": "object" },
		"marginMobile": { "type": "object" },
		"marginUnit": { "type": "string", "default": "px" },
		"borderRadius": { "type": "object" },
		"borderRadiusUnit": { "type": "string", "default": "px" },
		"boxShadow": { "type": "boolean", "default": false },
		"shadowHorizontal": { "type": "number", "default": 0 },
		"shadowVertical": { "type": "number", "default": 4 },
		"shadowBlur": { "type": "number", "default": 8 },
		"shadowSpread": { "type": "number", "default": 0 },
		"shadowColor": { "type": "string", "default": "rgba(0,0,0,0.12)" },
		"hideOnDesktop": { "type": "boolean", "default": false },
		"hideOnTablet": { "type": "boolean", "default": false },
		"hideOnMobile": { "type": "boolean", "default": false }
	},
	"textdomain": "wb-listora",
	"editorScript": "file:../../build/blocks/listing-submission/index.js",
	"viewScriptModule": "file:../../build/blocks/listing-submission/view.js",
	"style": "file:./style.css",
	"render": "file:./render.php"
}
