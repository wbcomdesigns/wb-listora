parameters:
	ignoreErrors:
		-
			message: '#^Parameter \#1 \$parent_slug of function add_submenu_page expects string, null given\.$#'
			identifier: argument.type
			count: 1
			path: includes/admin/class-admin.php

		-
			message: '#^Parameter \#1 \$text of function esc_attr expects string, float\|int given\.$#'
			identifier: argument.type
			count: 1
			path: includes/admin/class-admin.php

		-
			message: '#^Parameter \#1 \$text of function esc_html expects string, float\|int given\.$#'
			identifier: argument.type
			count: 1
			path: includes/admin/class-admin.php

		-
			message: '#^Parameter \#1 \$text of function esc_html expects string, int given\.$#'
			identifier: argument.type
			count: 2
			path: includes/admin/class-admin.php

		-
			message: '#^Strict comparison using \!\=\= between 0 and float will always evaluate to true\.$#'
			identifier: notIdentical.alwaysTrue
			count: 1
			path: includes/admin/class-admin.php

		-
			message: '#^Parameter \#1 \$text of function esc_attr expects string, int given\.$#'
			identifier: argument.type
			count: 1
			path: includes/admin/class-taxonomy-fields.php

		-
			message: '#^Parameter \#1 \$text of function esc_attr expects string, int given\.$#'
			identifier: argument.type
			count: 1
			path: includes/admin/class-type-editor.php

		-
			message: '#^Parameter \#1 \$text of function esc_html expects string, int given\.$#'
			identifier: argument.type
			count: 1
			path: includes/admin/class-type-editor.php

		-
			message: '#^Parameter \#1 \$text of function esc_html expects string, int\<0, max\> given\.$#'
			identifier: argument.type
			count: 1
			path: includes/admin/class-type-editor.php

		-
			message: '#^Unreachable statement \- code above always terminates\.$#'
			identifier: deadCode.unreachable
			count: 1
			path: includes/class-activator.php

		-
			message: '#^Parameter \#3 \$deps of function wp_register_script_module expects array\<int\|string, array\{id\: string, import\?\: string\}\>, array\{''@wordpress…''\} given\.$#'
			identifier: argument.type
			count: 1
			path: includes/class-plugin.php

		-
			message: '#^Parameter \#1 \$term_id of function wp_update_term expects int, string given\.$#'
			identifier: argument.type
			count: 1
			path: includes/core/class-listing-type-registry.php

		-
			message: '#^Method WBListora\\ImportExport\\CSV_Exporter\:\:export\(\) should return string but returns WP_Error\.$#'
			identifier: return.type
			count: 1
			path: includes/import-export/class-csv-exporter.php

		-
			message: '#^Parameter \#2 \$user_id of function get_the_author_meta expects int\|false, string given\.$#'
			identifier: argument.type
			count: 1
			path: includes/import-export/class-csv-exporter.php

		-
			message: '#^Method WBListora\\ImportExport\\CSV_Importer\:\:parse_preview\(\) should return array but returns WP_Error\.$#'
			identifier: return.type
			count: 1
			path: includes/import-export/class-csv-importer.php

		-
			message: '#^Parameter \#2 \$value of method WP_HTTP_Response\:\:header\(\) expects string, int given\.$#'
			identifier: argument.type
			count: 1
			path: includes/rest/class-claims-controller.php

		-
			message: '#^Parameter \#2 \$value of method WP_HTTP_Response\:\:header\(\) expects string, int given\.$#'
			identifier: argument.type
			count: 1
			path: includes/rest/class-favorites-controller.php

		-
			message: '#^Negated boolean expression is always true\.$#'
			identifier: booleanNot.alwaysTrue
			count: 1
			path: includes/rest/class-listing-types-controller.php

		-
			message: '#^Unreachable statement \- code above always terminates\.$#'
			identifier: deadCode.unreachable
			count: 1
			path: includes/rest/class-listing-types-controller.php

		-
			message: '#^Parameter \#2 \$value of method WP_HTTP_Response\:\:header\(\) expects string, int given\.$#'
			identifier: argument.type
			count: 2
			path: includes/rest/class-reviews-controller.php

		-
			message: '#^Result of && is always false\.$#'
			identifier: booleanAnd.alwaysFalse
			count: 1
			path: includes/rest/class-search-controller.php

		-
			message: '#^Strict comparison using \=\=\= between 0 and float will always evaluate to false\.$#'
			identifier: identical.alwaysFalse
			count: 1
			path: includes/rest/class-search-controller.php

		-
			message: '#^Variable \$ids in empty\(\) always exists and is not falsy\.$#'
			identifier: empty.variable
			count: 1
			path: includes/rest/class-search-controller.php

		-
			message: '#^Variable \$conditions in empty\(\) always exists and is not falsy\.$#'
			identifier: empty.variable
			count: 1
			path: includes/search/class-search-engine.php

		-
			message: '#^Call to function is_array\(\) with mixed will always evaluate to false\.$#'
			identifier: function.impossibleType
			count: 1
			path: includes/search/class-search-indexer.php

		-
			message: '#^Offset ''amount'' on \*NEVER\* in isset\(\) always exists and is not nullable\.$#'
			identifier: isset.offset
			count: 1
			path: includes/search/class-search-indexer.php

		-
			message: '#^Parameter \#2 \$user_id of function get_the_author_meta expects int\|false, string given\.$#'
			identifier: argument.type
			count: 1
			path: includes/workflow/class-notifications.php

		-
			message: '#^Expected 2 @param tags, found 3\.$#'
			identifier: paramTag.count
			count: 1
			path: includes/workflow/class-status-manager.php
